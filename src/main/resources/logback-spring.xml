<configuration>
  <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss} %-5level %logger{30} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="ARCHIVO" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/catalogo.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>logs/catalogo.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="com.empresa.catalogo" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="CONSOLA"/>
    <appender-ref ref="ARCHIVO"/>
  </root>
</configuration>
